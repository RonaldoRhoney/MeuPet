    {
      "parameters": {
        "url": "=https://dllchewamguyzudlkpxu.supabase.co/rest/v1/pets?id=eq.{{$json[0].pet_id}}&select=*,profiles!pets_owner_id_fkey(full_name)",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "SUA_SERVICE_ROLE_KEY_AQUI" },
            { "name": "Authorization", "value": "Bearer SUA_SERVICE_ROLE_KEY_AQUI" }
