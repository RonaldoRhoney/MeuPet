      "typeVersion": 3,
      "position": [620, 300],
      "retryOnFail": true,
      "waitBetweenTries": 300000
    },
    {
      "parameters": {
        "jsCode": "const pet = items[0].json[0];\nconst marcos = { 10:'estrela_nascente', 50:'popular', 100:'popular', 500:'viral', 1000:'lenda' };\nconst score = pet.rank_score;\nconst atingiuMarco = [10,50,100,500,1000].includes(score);\nlet badge = null;\nif (score >= 1000) badge = 'lenda';\nelse if (score >= 500) badge = 'viral';\nelse if (score >= 50) badge = 'popular';\nelse if (score >= 10) badge = 'estrela_nascente';\nreturn [{ json: { ...pet, atingiu_marco: atingiuMarco, badge_calculado: badge } }];"
      },
      "id": "code3",
      "name": "Verifica marco",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [840, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            { "value1": "={{$json.atingiu_marco}}", "value2": true }
          ]
        }
      },
      "id": "if3",
      "name": "Atingiu marco?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1060, 300]
    },
    {
      "parameters": {
        "chatId": "SEU_TELEGRAM_CHAT_ID_AQUI",
        "text": "=🏆 *Marco de curtidas atingido!*\n🐾 Pet: {{$json.name}} ({{$json.species}})\n👑 Curtidas: {{$json.rank_score}}\n📍 Cidade: {{$json.city || 'não informado'}}\n👤 Dono: {{$json.profiles.full_name}}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "telegram3",
      "name": "Telegram - avisa admin",
